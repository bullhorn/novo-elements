{
  "name": "novo-elements",
  "version": "12.0.0",
  "description": "Bullhorn's Novo-Elements repository, including core projects and tools",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "bullhorn/novo-elements"
  },
  "scripts": {
    "build": "ng build novo-elements",
    "postbuild": "npm run copy:scss && npm run build:examples",
    "build:ci": "ng build novo-elements",
    "postbuild:ci": "npm run copy:resources",
    "build:watch": "ng build novo-elements --watch",
    "build:demo": "ng build demo",
    "build:schematics": "tsc -p ./projects/schematics/tsconfig.json",
    "prebuild:examples": "npm run generate:all",
    "build:examples": "ng build novo-examples",
    "build:examples:watch": "ng build novo-examples --watch",
    "watch:examples": "npm-watch generate:all",
    "generate:examples": "tsx ./tools/examples-module.ts",
    "generate:routes": "tsx ./tools/examples-routes.ts",
    "generate:all": "npm run generate:examples && npm run generate:routes",
    "start": "ng serve demo",
    "copy:resources": "npm run copy:scss",
    "copy:schematics": "npx copyfiles -f projects/schematics/*.json dist/novo-elements/schematics/",
    "copy:scss": "node copy-scss.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:typecheck": "tsc --noEmit -p tsconfig.spec.json",
    "lint": "eslint \"projects/**/*.{ts,tsx}\" && htmlhint \"projects\" --config .htmlhintrc",
    "lint:fix": "eslint \"projects/**/*.{ts,tsx}\" --fix",
    "lint:html": "htmlhint \"projects\" --config .htmlhintrc",
    "lint:scss": "stylelint \"projects/**/*.scss\"",
    "compat": "ngcc ... --tsconfig './projects/novo-elements/tsconfig.lib.json'",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "version:elements": "standard-version",
    "release:elements": "standard-version",
    "postrelease:elements": "git push --follow-tags origin master; npm run build; cd dist/novo-elements && npm publish",
    "snapshot-publish": "bash snapshot-publish",
    "prettier": "prettier --write \"./projects/**/*.{ts,js,html,scss}\"",
    "prettier:check": "prettier --list-different \"./projects/**/*.{ts,js,html,scss}\"",
    "e2e": "wdio run projects/novo-e2e/wdio.conf.ts --headless=true",
    "e2e:single": "bash -c 'wdio run projects/novo-e2e/wdio.conf.ts --spec \"projects/novo-e2e/src/e2e/$1.e2e.ts\" --headless=true \"${@:2}\"' --",
    "e2e:single:headed": "bash -c 'wdio run projects/novo-e2e/wdio.conf.ts --spec \"projects/novo-e2e/src/e2e/$1.e2e.ts\" --headless=false \"${@:2}\"' --",
    "e2e:headed": "wdio run projects/novo-e2e/wdio.conf.ts --headless=false",
    "e2e:headless": "wdio run projects/novo-e2e/wdio.conf.ts --headless=true"
  },
  "dependencies": {
    "@angular/animations": "^22.0.1",
    "@angular/cdk": "^22.0.1",
    "@angular/common": "^22.0.1",
    "@angular/compiler": "^20.3.18",
    "@angular/core": "^22.0.1",
    "@angular/forms": "^22.0.1",
    "@angular/platform-browser": "^22.0.1",
    "@angular/platform-browser-dynamic": "^22.0.1",
    "@angular/platform-server": "^22.0.1",
    "@angular/router": "^22.0.1",
    "@codemirror/commands": "^6.10.2",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.16",
    "angular-imask": "^7.6.1",
    "codemirror": "6.0.2",
    "date-fns": "4.1.0",
    "imask": "^7.6.1",
    "novo-design-tokens": "^0.1.4",
    "post-robot": "9.0.36",
    "rxjs": "~7.8.2",
    "timezone-support": "^3.1.0",
    "tslib": "^2.8.1",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/core": "^20.3.22",
    "@angular-devkit/schematics": "^20.3.22",
    "@angular/build": "^22.0.1",
    "@angular/cli": "^20.3.22",
    "@angular/compiler-cli": "^20.3.18",
    "@angular/language-service": "^20.3.18",
    "@bullhorn/bullhorn-icons": "^2.42.2",
    "@codemirror/lang-javascript": "^6.2.4",
    "@eslint/js": "^10.0.1",
    "@github-docs/frontmatter": "^1.3.1",
    "@schematics/angular": "^20.3.22",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^13.1.4",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@swc/core": "^1.15.33",
    "@types/fs-extra": "^11.0.4",
    "@types/glob": "^9.0.0",
    "@types/node": "^22.19.13",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/eslint-plugin": "^1.6.16",
    "@wdio/cli": "^9.27.0",
    "@wdio/dot-reporter": "^9.27.0",
    "@wdio/globals": "^9.27.0",
    "@wdio/junit-reporter": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/spec-reporter": "^9.27.0",
    "angular-split": "^20.0.0",
    "chromedriver": "^143.0.2",
    "conventional-changelog-cli": "~5.0.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unused-imports": "^4.4.1",
    "expect-webdriverio": "^5.6.5",
    "fs-extra": "^11.3.3",
    "full-icu": "^1.5.0",
    "glob": "^13.0.6",
    "happy-dom": "^20.9.0",
    "highlight.js": "^11.11.1",
    "htmlhint": "^1.9.1",
    "husky": "^9.1.7",
    "markdown-it": "^14.1.1",
    "markdown-it-attrs": "^4.3.1",
    "markdown-it-container": "^4.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "ng-packagr": "20.3.2",
    "npm-watch": "^0.13.0",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "pretty-quick": "^4.2.2",
    "reflect-metadata": "^0.2.2",
    "semantic-release": "^25.0.3",
    "standard-version": "^9.5.0",
    "stylelint": "~16.26.1",
    "stylelint-config-prettier": "^8.0.2",
    "stylelint-config-recommended-scss": "~16.0.2",
    "stylelint-config-standard": "~39.0.1",
    "stylelint-scss": "~6.14.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "unplugin-swc": "^1.5.9",
    "vite": "^7.3.2",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "@angular/build": {
      "vitest": "$vitest"
    },
    "keyv": "^5.6.0"
  },
  "lint-staged": {
    "*.{ts,json,scss,css,html}": [
      "prettier --write",
      "git add"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "pretty-quick --staged"
    }
  },
  "watch": {
    "generate:all": {
      "patterns": [
        "projects/novo-examples"
      ],
      "extensions": "md,ts,html,scss",
      "ignore": "projects/novo-examples/src/examples.*.ts",
      "quiet": false
    }
  }
}
